<script type="text/javascript">
  $('.btn-show').click(function (e) {
    e.preventDefault();
    var $btn = $(this);
    var $target = $btn.attr('data-target');

    $btn.toggleClass('active');
    $($target).toggleClass('open');
  });
</script>
