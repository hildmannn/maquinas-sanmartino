    $(".removeItem").click(function () {
      $.ajax({
        type: "POST",
        dataType: 'json',
        url: '/delete-item.html',
        data: { producto_id: $(this).attr('rel') },
        success: function (msg) {
          refreshCarrito();
          refreshResume();
          mensaje(msg.mensaje, msg.success);
        }
      })
    });
  </script>

  
